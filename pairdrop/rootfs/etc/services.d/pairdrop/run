#!/usr/bin/env bashio
set +u

bashio::log.info "Starting PairDrop add-on"

LOCATION="$(bashio::config 'data_location')"
if [[ "$LOCATION" = "null" || -z "$LOCATION" ]]; then LOCATION=/config; fi
DEBUG_MODE="$(bashio::config 'debug_mode')"
export DEBUG_MODE

mkdir -p "$LOCATION"
export PORT=8080
cd /app/pairdrop

RATE_LIMIT="$(bashio::config 'rate_limit')"
WS_FALLBACK="$(bashio::config 'ws_fallback')"

OPT_ARGS=""
if [[ "${RATE_LIMIT:-}" = "true" ]]; then OPT_ARGS="$OPT_ARGS --rate-limit"; fi
if [[ "${WS_FALLBACK:-}" = "true" ]]; then OPT_ARGS="$OPT_ARGS --include-ws-fallback"; fi

bashio::log.info "Data location: ${LOCATION}"
bashio::log.info "Starting PairDrop server on port 8080..."

exec node server/index.js $OPT_ARGS
